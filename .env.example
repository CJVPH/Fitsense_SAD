# FitSense Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=fitsense_db
DB_USER=root
DB_PASS=

# ── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Application ───────────────────────────────────────────────────────────────
BASE_URL=http://localhost/fitsense/
